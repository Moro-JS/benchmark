{
  "name": "morojs-benchmarks",
  "version": "1.0.0",
  "description": "Performance benchmarks for MoroJS framework",
  "private": true,
  "type": "module",
  "scripts": {
    "bench": "node bench.js all",
    "bench:quick": "node bench.js all --quick",
    "bench:save": "node bench.js all --save",
    "bench:single": "node bench.js single",
    "bench:engine": "node bench.js engine",
    "bench:cluster": "node bench.js cluster",
    "bench:uws": "node bench.js uws",
    "bench:fastify": "node bench.js fastify",
    "bench:express": "node bench.js express",
    "bench:koa": "node bench.js koa",
    "bench:hono": "node bench.js hono",
    "bench:raw-node": "node bench.js raw-node",
    "bench:raw-uws": "node bench.js raw-uws",
    "server:single": "NODE_ENV=production LOG_LEVEL=warn PORT=3110 node servers/moro-single-server.js",
    "server:cluster": "NODE_ENV=production LOG_LEVEL=warn PORT=3111 node servers/moro-cluster-server.js",
    "server:uws": "NODE_ENV=production LOG_LEVEL=warn PORT=3112 node servers/moro-uws-server.js",
    "bench:elysia-bun": "node bench.js elysia-bun",
    "bench:elysia-node": "node bench.js elysia-node",
    "bench:raw-bun": "node bench.js raw-bun",
    "local:link": "node -e \"const fs=require('fs');const p='node_modules/moro-local';fs.rmSync(p,{recursive:true,force:true});fs.symlinkSync('../../MoroJS',p,'dir');console.log('linked moro-local -> ../MoroJS ('+require('./'+p+'/package.json').version+')')\"",
    "local:unlink": "node -e \"require('fs').rmSync('node_modules/moro-local',{recursive:true,force:true});console.log('moro-local unlinked')\"",
    "local:build": "npm --prefix ../MoroJS run build",
    "bench:single-local": "node bench.js single-local",
    "bench:engine-local": "node bench.js engine-local",
    "bench:uws-local": "node bench.js uws-local",
    "bench:cluster-local": "node bench.js cluster-local",
    "bench:ab": "node bench.js single single-local",
    "bench:ab-uws": "node bench.js uws uws-local",
    "bench:ab-engine": "node bench.js engine engine-local",
    "bench:engine-vs-uws": "node bench.js engine-local uws-local --pipelined"
  },
  "dependencies": {
    "@elysiajs/node": "^1.4.5",
    "@hono/node-server": "^2.0.8",
    "@morojs/engine": "^1.1.2",
    "@morojs/moro": "latest",
    "autocannon": "^8.0.0",
    "elysia": "^1.4.29",
    "express": "^5.2.1",
    "fastify": "^5.9.0",
    "hono": "^4.12.29",
    "koa": "^3.2.1",
    "uWebSockets.js": "github:uNetworking/uWebSockets.js#semver:^v20.52.0"
  },
  "keywords": [
    "benchmark",
    "performance",
    "morojs",
    "autocannon"
  ]
}
